<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- App bar con elevation y titulo prominente -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="0dp"
        android:background="?attr/colorSurface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="@string/community_share_title"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/colorOnSurface"
            app:navigationContentDescription="@string/back_button_description" />

        <!-- Divisor sutil bajo el toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:importantForAccessibility="no" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <!-- Seccion: titulo del post -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/community_post_title_hint"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/title_layout"
                style="@style/Widget.TrazaGo.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/community_post_title_hint"
                app:counterEnabled="true"
                app:counterMaxLength="80"
                app:boxStrokeColor="@color/md_theme_light_primary"
                app:hintTextColor="?attr/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/title_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLength="80"
                    android:singleLine="true"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Seccion: contenido del post -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/community_post_content_hint"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/content_layout"
                style="@style/Widget.TrazaGo.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/community_post_content_hint"
                app:counterEnabled="true"
                app:counterMaxLength="1000"
                app:boxStrokeColor="@color/md_theme_light_primary"
                app:hintTextColor="?attr/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/content_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLength="1000"
                    android:minLines="5"
                    android:gravity="top|start"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:lineSpacingMultiplier="1.4" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Seccion: fotos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/community_add_photos"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

            <!-- Boton de fotos con icono y estilo outlined -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_photos"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/community_add_photos"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:icon="@drawable/ic_add_photo"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:cornerRadius="14dp"
                app:strokeWidth="2dp"
                app:strokeColor="?attr/colorOutline" />

            <!-- Miniaturas de fotos seleccionadas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/photos_recycler"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:paddingEnd="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Seccion: etiquetar lugar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/community_tag_place"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tag_place"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/community_tag_place"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:icon="@drawable/ic_location"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:cornerRadius="14dp" />

            <!-- Chip del lugar etiquetado -->
            <com.google.android.material.chip.Chip
                android:id="@+id/tagged_place_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Chip.Input"
                app:closeIconVisible="true"
                app:chipBackgroundColor="@color/md_theme_light_secondaryContainer"
                app:chipIconTint="@color/md_theme_light_secondary"
                android:textColor="@color/md_theme_light_onSecondaryContainer"
                app:chipIcon="@drawable/ic_location" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Boton publicar fijo al fondo con shadow card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:importantForAccessibility="no" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_publish"
            style="@style/Widget.TrazaGo.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:minHeight="52dp"
            android:text="@string/community_publish"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
