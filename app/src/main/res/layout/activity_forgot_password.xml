<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    tools:context=".ForgotPasswordActivity">

    <!-- paddingTop dinámico vía BaseActivity.applyWindowInsets() -->
    <LinearLayout
        android:id="@+id/forgot_password_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="@dimen/space_24"
        android:paddingTop="@dimen/space_24"
        android:paddingBottom="@dimen/space_32">

        <!-- Back en línea con el contenido -->
        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/colorOnBackground"
            android:contentDescription="Volver" />

        <!-- Ilustración: círculo + candado -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="@dimen/space_32"
            android:background="@drawable/bg_circle_accent">

            <ImageView
                android:id="@+id/lock_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock_outline_black_24dp"
                app:tint="?attr/colorPrimary"
                android:contentDescription="@string/cd_lock_icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/forgot_password_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:text="@string/forgot_password_link"
            android:textAppearance="@style/TextAppearance.TrazaGo.HeadlineSmall"
            android:textAlignment="center"
            android:gravity="center"
            android:accessibilityHeading="true" />

        <TextView
            android:id="@+id/forgot_password_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="@string/forgot_subtitle"
            android:textAppearance="@style/TextAppearance.TrazaGo.BodyMedium"
            android:textAlignment="center"
            android:gravity="center" />

        <!-- Email input Material 3 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email_input_layout"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_32"
            android:hint="@string/email_hint"
            app:boxBackgroundColor="?attr/colorSurfaceVariant"
            app:boxCornerRadiusTopStart="@dimen/radius_md"
            app:boxCornerRadiusTopEnd="@dimen/radius_md"
            app:boxCornerRadiusBottomStart="@dimen/radius_md"
            app:boxCornerRadiusBottomEnd="@dimen/radius_md"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:endIconMode="clear_text"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/email_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reset_password_button"
            style="@style/Widget.TrazaGo.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/space_24"
            android:text="@string/forgot_send_link" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/back_to_login_text_view"
            style="@style/Widget.TrazaGo.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="@string/back_to_login"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>
</ScrollView>
