<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <!-- Lottie Animation o ProgressBar -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_indicator"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:indeterminate="true"
        app:indicatorSize="64dp"
        app:trackThickness="6dp" />

    <!-- Emoji animado -->
    <TextView
        android:id="@+id/emoji_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="🤖"
        android:textSize="48sp" />

    <!-- Título -->
    <TextView
        android:id="@+id/progress_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:text="Generando tu ruta perfecta"
        android:textAppearance="@style/TextAppearance.TrazaGo.TitleMedium"
        android:textAlignment="center"
        android:gravity="center" />

    <!-- Mensaje de estado -->
    <TextView
        android:id="@+id/progress_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="Analizando tus preferencias…"
        android:textAppearance="@style/TextAppearance.TrazaGo.BodyMedium"
        android:textAlignment="center"
        android:gravity="center" />

    <!-- Mensaje de tips -->
    <TextView
        android:id="@+id/progress_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:padding="@dimen/space_12"
        android:text="💡 La IA está seleccionando los mejores lugares según tu presupuesto y tiempo"
        android:textAppearance="@style/TextAppearance.TrazaGo.BodySmall"
        android:textAlignment="center"
        android:gravity="center"
        android:background="@drawable/bg_rounded_light"
        android:alpha="0.85" />

</LinearLayout>
