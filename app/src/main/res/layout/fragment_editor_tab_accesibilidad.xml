<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSillaRuedas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accesible en silla de ruedas"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swBanoAccesible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Baño accesible"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swEstacionamiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estacionamiento disponible"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swEstacionamientoAccesible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estacionamiento accesible"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swBraille"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Señalización en Braille"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNotasAccesibilidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notas de accesibilidad"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotasAccesibilidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
