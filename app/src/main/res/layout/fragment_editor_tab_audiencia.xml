<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swAptoNinos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apto para niños"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swAptoMascotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apto para mascotas"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dificultad física (1=muy fácil · 5=muy difícil)"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/sliderDificultad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="4"
            android:progress="0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDificultadLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorPrimary"
            android:text="1 — Muy fácil"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audiencia ideal"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/cbSolo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solo/a" />

        <CheckBox
            android:id="@+id/cbPareja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pareja" />

        <CheckBox
            android:id="@+id/cbFamilia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Familia" />

        <CheckBox
            android:id="@+id/cbAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Amigos" />

        <CheckBox
            android:id="@+id/cbNinos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Niños" />

        <CheckBox
            android:id="@+id/cbMayores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adultos mayores" />

    </LinearLayout>
</ScrollView>
