<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swCerradoTemporalmente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrado temporalmente"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilHorariosTexto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Horarios (texto libre)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHorariosTexto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:hint="Ej: Lunes-Viernes 9:00-18:00&#10;Sábado 10:00-14:00&#10;Domingo cerrado" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Los horarios estructurados por día se generan automáticamente al enriquecer con IA (tab Tags/IA)."
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
