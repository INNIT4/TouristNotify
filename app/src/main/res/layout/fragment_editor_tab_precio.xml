<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tipo de actividad -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTipoActividad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tipo de actividad"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginBottom="16dp">
            <AutoCompleteTextView
                android:id="@+id/actvTipoActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Precio -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swEntradaGratuita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entrada gratuita"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nivel de precio (0=Gratis · 4=$$$$)"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/sliderPrecioNivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="4"
            android:progress="0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPrecioNivelLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorPrimary"
            android:text="0 — Gratis"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPrecioPromedio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Precio promedio (MXN)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrecioPromedio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Duración -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDuracionMin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duración mínima sugerida (minutos)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDuracionMin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDuracionMax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Duración máxima sugerida (minutos)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDuracionMax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mejor momento -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMejorMomento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mejor momento del día (ej: MAÑANA, TARDE)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMejorMomento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMejorTemporada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mejor temporada (ej: Invierno, Primavera)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMejorTemporada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEpocasEvitar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Épocas a evitar (ej: Semana Santa, Agosto)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEpocasEvitar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
