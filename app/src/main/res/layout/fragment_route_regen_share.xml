<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Sección regenerar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Regenerar ruta"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="¿Qué quieres cambiar?"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- Chips de feedback preset -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMasRelajada"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más relajada" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMasBarata"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más barata" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMasCultural"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más cultural" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMenosCaminata"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menos caminata" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMasGastronomia"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más gastronomía" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMasNaturaleza"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Más naturaleza" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Feedback libre -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFeedbackLibre"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="¿Algo más? (opcional)"
            app:counterEnabled="true"
            app:counterMaxLength="200">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFeedbackLibre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLength="200"
                android:minLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Indicador progreso regeneración -->
        <LinearLayout
            android:id="@+id/layoutRegenerando"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:indicatorSize="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Regenerando ruta..."
                android:textAppearance="?attr/textAppearanceBodySmall" />

        </LinearLayout>

        <!-- Botón regenerar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegenerar"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Regenerar con este feedback"
            app:icon="@android:drawable/ic_menu_rotate" />

        <!-- Divider -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp" />

        <!-- Sección compartir -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compartir ruta"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <!-- Botón Google Maps -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAbrirGoogleMaps"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Abrir en Google Maps"
            app:icon="@android:drawable/ic_dialog_map" />

        <!-- Botón compartir texto -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompartirTexto"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Compartir como texto"
            app:icon="@android:drawable/ic_menu_share" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>

</ScrollView>
