<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Handle de drag -->
        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Arrastrar para reordenar"
            android:alpha="0.5" />

        <!-- Número de orden -->
        <TextView
            android:id="@+id/tvEditorOrden"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_primary"
            android:gravity="center"
            android:text="1"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnPrimary" />

        <!-- Info del lugar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEditorNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del lugar"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvEditorHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="09:00–10:30"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Botón quitar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuitarParada"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@android:drawable/ic_delete"
            app:iconTint="?attr/colorError"
            android:contentDescription="Quitar parada" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
