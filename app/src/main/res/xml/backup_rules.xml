<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android Auto Backup (API < 31).
   See https://developer.android.com/guide/topics/data/autobackup

   IMPORTANTE: TouristNotifyPrefs y TouristNotifyUsage son EncryptedSharedPreferences.
   La clave maestra (Android Keystore) NO se respalda con Auto Backup, por lo que
   restaurar el archivo cifrado en otro dispositivo lo deja inservible. Excluirlos
   del backup además protege la app si en el futuro se almacenan tokens.
-->
<full-backup-content>
    <!-- Excluir EncryptedSharedPreferences (la master key no se respalda) -->
    <exclude domain="sharedpref" path="TouristNotifyPrefs.xml" />
    <exclude domain="sharedpref" path="TouristNotifyUsage.xml" />

    <!-- Excluir tokens de Firebase Auth -->
    <exclude domain="sharedpref" path="com.google.firebase.auth.api.Store.xml" />

    <!-- Excluir Room DB (cache local de Firestore) -->
    <exclude domain="database" path="tourist_notify_db" />
    <exclude domain="database" path="tourist_notify_db-journal" />
    <exclude domain="database" path="tourist_notify_db-wal" />
    <exclude domain="database" path="tourist_notify_db-shm" />
    <exclude domain="database" path="tourist_notify_database" />

    <!-- Excluir caches -->
    <exclude domain="root" path="cache/" />
</full-backup-content>
